{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadHypothesisStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::nangman-crypto-dev-intel-candidate-<account-suffix>"
    },
    {
      "Sid": "ReadHypothesisStateObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::nangman-crypto-dev-intel-candidate-<account-suffix>/hypothesis-state/schema=intel_candidate_hypothesis_state_v1/*",
        "arn:aws:s3:::nangman-crypto-dev-intel-candidate-<account-suffix>/candidate-evidence-bundle/priority=p2/*"
      ]
    },
    {
      "Sid": "ReadMarketFeatureDeltaBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::nangman-crypto-dev-market-ingest-l1-<account-suffix>"
    },
    {
      "Sid": "ReadMarketFeatureDeltaObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::nangman-crypto-dev-market-ingest-l1-<account-suffix>/market_feature_delta/*",
        "arn:aws:s3:::nangman-crypto-dev-market-ingest-l1-<account-suffix>/market_feature_delta_summary/*"
      ]
    },
    {
      "Sid": "ValidateResearchOutputBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::nangman-crypto-dev-research-<account-suffix>"
    },
    {
      "Sid": "ReadHistoricalReplayIndex",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::nangman-crypto-dev-research-<account-suffix>/replay-run-index/*"
    },
    {
      "Sid": "WriteHarnessOutputs",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": [
        "arn:aws:s3:::nangman-crypto-dev-research-<account-suffix>/hypothesis-harness/hypothesis-harness-result/*",
        "arn:aws:s3:::nangman-crypto-dev-research-<account-suffix>/hypothesis-harness/hypothesis-harness-report/*",
        "arn:aws:s3:::nangman-crypto-dev-research-<account-suffix>/research-input-manifest/*"
      ]
    }
  ]
}
